# Supabase project URL — Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Password that unlocks the /admin panel (any string you choose)
ADMIN_PASSWORD=

# API Ninjas key for the Word Generator — https://api-ninjas.com/ (free tier)
# Used server-side only by /api/word so it's never exposed to the client.
API_NINJAS_KEY=
